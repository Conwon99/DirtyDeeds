---
import '../styles/global.css';
import { MobileStickyContact } from '@/components/MobileStickyContact';
import { business, homepageDescription } from '@/data/business';
import { locations } from '@/data/locations';
import { reviews, TOTAL_REVIEW_COUNT } from '@/data/reviews';
import { CANONICAL_PHONE_TEL } from '@/utils/phoneTracking';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  ogImage?: string;
  robots?: string;
}

const { title, description, canonical, keywords, ogImage, robots } = Astro.props;
const defaultDescription = homepageDescription();
const defaultKeywords = `driveway cleaning ${business.region}, roof cleaning ${business.region}, patio cleaning ${business.region}, gutter clearing, exterior cleaning, ${business.alternateName} ${business.region}`;
const siteUrl = business.siteUrl;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const defaultOgImage = ogImage || `${siteUrl}${business.assets.hero}`;
const logoUrl = `${siteUrl}${business.assets.logo}`;
const pageDescription = description || defaultDescription;
const businessSchema = {
  "@context": "https://schema.org",
  "@type": ["HomeAndConstructionBusiness", "LocalBusiness"],
  "@id": `${siteUrl}/#business`,
  "name": business.businessName,
  "alternateName": business.alternateName,
  "description": defaultDescription,
  "url": siteUrl,
  "telephone": CANONICAL_PHONE_TEL,
  "email": business.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": business.address.addressLocality,
    "addressRegion": business.address.addressRegion,
    "addressCountry": business.address.addressCountry
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": business.region },
    ...locations.map((location) => ({
      "@type": "Place",
      "name": location.name,
    })),
  ],
  "serviceType": business.serviceTypes,
  "sameAs": [business.facebookUrl],
  "hasMap": business.googleMapsUrl,
  "priceRange": "££",
  "openingHoursSpecification": business.openingHours.map((hours) => ({
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": hours.dayOfWeek,
    "opens": hours.opens,
    "closes": hours.closes
  })),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": String(TOTAL_REVIEW_COUNT),
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": reviews.slice(0, 2).map((review) => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": review.name },
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "reviewBody": review.text
  })),
  "logo": {
    "@type": "ImageObject",
    "url": logoUrl
  },
  "image": [
    logoUrl,
    `${siteUrl}${business.assets.hero}`,
    `${siteUrl}${business.assets.about}`,
    ...business.assets.gallery.map((image) => `${siteUrl}${image}`)
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": CANONICAL_PHONE_TEL,
    "contactType": "customer service",
    "areaServed": business.geoRegion,
    "availableLanguage": "English"
  }
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": business.alternateName,
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}/#business` },
  "inLanguage": "en-GB"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords || defaultKeywords} />
    <meta name="author" content={business.alternateName} />
    <meta name="language" content="English" />
    <meta name="geo.region" content={business.geoRegion} />
    <meta name="geo.placename" content={`${business.primaryCity} and ${business.secondaryCity}`} />
    <meta name="theme-color" content="#15803d" />
    <meta name="robots" content={robots || "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Hreflang for UK targeting -->
    <link rel="alternate" hreflang="en-gb" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={defaultOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${business.alternateName} exterior cleaning work in ${business.region}`} />
    <meta property="og:site_name" content={business.alternateName} />
    <meta property="og:locale" content="en_GB" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={defaultOgImage} />
    <meta name="twitter:image:alt" content={`${business.alternateName} exterior cleaning work in ${business.region}`} />
    
    <link rel="icon" type="image/png" href={business.assets.logo} />
    <link rel="apple-touch-icon" href={business.assets.logo} />
    <meta name="generator" content={Astro.generator} />
    
    {business.googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${business.googleAnalyticsId}`}></script>
        <script is:inline define:vars={{ gaId: business.googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    {business.googleAdsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${business.googleAdsId}`}></script>
        <script is:inline define:vars={{ adsId: business.googleAdsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', adsId);
        </script>
      </>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body>
    <slot />
    <MobileStickyContact client:load />
  </body>
</html>
